# Supabase Configuration
# Get these from https://supabase.com/dashboard/projects
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin Authentication
# Simple password for /admin login (change this immediately after first login)
ADMIN_PASSWORD=change_me_to_secure_password

# Google Gemini AI (for product image generation and AI descriptions)
# Get key from https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_google_gemini_api_key

# Anthropic Claude (for "Write this for me" product descriptions)
# Get key from https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# Resend Email Service (for low-stock alerts and notifications)
# Get key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key

# Meta WhatsApp Business API (for order notifications and customer updates)
# Get from https://business.facebook.com/
WHATSAPP_BUSINESS_API_TOKEN=your_whatsapp_business_token
WHATSAPP_BUSINESS_PHONE_ID=your_whatsapp_business_phone_id

# Business Configuration
ADMIN_WHATSAPP_NUMBER=+27684472974
ADMIN_EMAIL=thobani.mbatha23@gmail.com
DELIVERY_FEE_ZAR=50
LOW_STOCK_THRESHOLD=5

# Payment Gateway (Paystack or Yoco - configure one or both)
# Paystack: https://dashboard.paystack.com
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# Yoco: https://console.yoco.com/
YOCO_API_KEY=your_yoco_api_key
YOCO_SECRET_KEY=your_yoco_secret_key

# N8n Webhook URLs (for automation workflows - optional for local dev)
N8N_WEBHOOK_NEW_ORDER=https://your-n8n-instance.com/webhook/order
N8N_WEBHOOK_ORDER_STATUS=https://your-n8n-instance.com/webhook/status
N8N_WEBHOOK_LOW_STOCK=https://your-n8n-instance.com/webhook/stock

# Vercel Environment
# These are auto-set by Vercel, but useful for local development
VERCEL_ENV=development
NODE_ENV=development
